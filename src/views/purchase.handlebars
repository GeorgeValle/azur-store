<div class="page-header">
  <h1 class="mx-3">Comprar</h1>
</div>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
  <div class="container-fluid">
    <a class="navbar-brand text-center fw-bolder text-white text-wrap" href="#">Azur Store</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarPurchase"
      aria-controls="navbarPurchase" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarPurchase">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        {{#if admin}}
        <li class="nav-item">
          <a class="nav-link" href="/session/inputProduct">Editar Productos</a>
        </li>
        {{/if}}

        <li class="nav-item">
          <a class="nav-link" href="/session/cart">Carrito</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/session/logout">Salir</a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<section class="container py-4">
  <div class="card mb-4 border-0 shadow-sm">
    <div class="row g-0 align-items-center">
      <div class="col-md-3">
        <img src="{{avatar}}" class="img-fluid rounded-start w-100" alt="Foto de Perfil">
      </div>

      <div class="col-md-9">
        <div class="card-body p-4">
          <span class="badge text-bg-primary mb-2">Bienvenido</span>
          <h2 class="h4 mb-2">{{user}}</h2>
          <p class="text-muted mb-0">Explorá el catálogo y agregá libros al carrito sin recargar toda la vista.</p>
          {{#if message}}
          <p class="text-success fw-semibold mt-3 mb-0">{{message}}</p>
          {{/if}}
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
      <h3 class="h5 mb-1">Catálogo</h3>
      <p class="text-muted mb-0">Los productos ahora se cargan con fetch desde <code>/products</code>.</p>
    </div>

    <div class="d-flex gap-2">
      <a href="/session/cart" class="btn btn-dark">Ver carrito</a>
    </div>
  </div>

  <div id="purchase-feedback" class="mb-3"></div>

  <div
    id="products-root"
    class="row g-4"
    data-user-id="{{userId}}"
    aria-live="polite"
  >
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <p class="mb-0 text-muted">Cargando productos...</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="/content/js/purchase.js"></script>